MyInterface.java
package mypack;   // User defined package

public interface MyInterface {
    void display();
}

MyClass.java
package mypack;   // Same package

public class MyClass implements MyInterface {

    public void display() {
        System.out.println("Interface method implemented");
    }
}

TestPackage.java
import mypack.MyClass;   // Import user defined package

class TestPackage {
    public static void main(String[] args) {
        MyClass obj = new MyClass();
        obj.display();
    }
}
